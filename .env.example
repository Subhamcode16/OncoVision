# --- ONCOVISION AI ENVIRONMENT TEMPLATE ---

# 1. API KEYS
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. SERVER CONFIGURATION
# Port for the FastAPI server (Render/Heroku will set this automatically)
PORT=8000

# 3. SECURITY & CORS
# The URL of your deployed Frontend (e.g., https://oncovision.vercel.app)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed hostnames (e.g., oncovision-api.onrender.com,localhost)
ALLOWED_HOSTS=localhost,127.0.0.1

# 4. DEPLOYMENT FLAG
# Set to 'production' to enable stricter security policies
ENVIRONMENT=development
